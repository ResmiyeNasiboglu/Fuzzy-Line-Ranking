   "source": [
    "import pandas as pd\n",
    "from scipy.stats import spearmanr\n",
    "\n",
    "# 1. Load the data files\n",
    "db_yolu = r\""\n",
    "\n",
    "# The files appear to be tab-delimited based on your snippets\n",
    "df_flr = pd.read_csv(db_yolu+r\"\\FLR İzmir results.txt\", sep='\\t')\n",
    "df_lr = pd.read_csv(db_yolu+\"\\LR İzmir results.txt\", sep='\\t')\n",
    "\n",
    "# 2. Standardize column names for merging\n",
    "# Your files use \"Line No\" and \"Rank Score\"\n",
    "df_flr.columns = ['LineNo', 'Score_FLR']\n",
    "df_lr.columns = ['LineNo', 'Score_LR']\n",
    "\n",
    "# 3. Merge the datasets on LineNo\n",
    "# This ensures we are comparing the same bus lines across both algorithms\n",
    "df_merged = pd.merge(df_flr, df_lr, on='LineNo')\n",
    "\n",
    "# 4. Calculate Spearman's Rank Correlation\n",
    "# The spearmanr function automatically converts scores into ranks internally\n",
    "rho, p_value = spearmanr(df_merged['Score_FLR'], df_merged['Score_LR'])\n",
    "\n",
    "print(f\"Total lines analyzed: {len(df_merged)}\")\n",
    "print(f\"Spearman's Rho (ρ): {rho:.4f}\")\n",
    "print(f\"P-value: {p_value:.4e}\")\n",
    "\n",
    "# 5. Export the aligned ranking table to a text file for the article appendix\n",
    "# We add the actual rank positions (1, 2, 3...) for clarity\n",
    "df_merged['Rank_FLR'] = df_merged['Score_FLR'].rank(ascending=False)\n",
    "df_merged['Rank_LR'] = df_merged['Score_LR'].rank(ascending=False)\n",
    "\n",
    "df_merged.to_csv(db_yolu+r\"\\Spearman_Rank_Comparison.txt\", sep='\\t', index=False)\n",
    "print(\"Aligned rankings saved to 'Spearman_Rank_Comparison.txt'\")"
   ]
  }
 ],
